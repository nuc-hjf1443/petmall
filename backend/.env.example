# App
PETMALL_APP_NAME=PetMall
PETMALL_ENV=local
PETMALL_DEBUG=true

# API
PETMALL_API_HOST=127.0.0.1
PETMALL_API_PORT=8000
PETMALL_PUBLIC_H5_URL=http://127.0.0.1:8080
PETMALL_CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# Database
PETMALL_MYSQL_DB_URI=mysql+aiomysql://root:change_me@127.0.0.1:3306/petmall?charset=utf8mb4

# Redis
PETMALL_REDIS_URL=redis://127.0.0.1:6379/0

# Auth
PETMALL_JWT_SECRET_KEY=change_me_in_local_env
PETMALL_JWT_ALGORITHM=HS256
PETMALL_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Local files
PETMALL_GENERATED_ASSET_DIR=generated
PETMALL_MAX_UPLOAD_SIZE_MB=20

# Mail
PETMALL_MAIL_USERNAME=
PETMALL_MAIL_PASSWORD=
PETMALL_MAIL_FROM=
PETMALL_MAIL_SERVER=
PETMALL_MAIL_PORT=465

# Payment
PETMALL_MOCK_PAYMENT_ENABLED=true
PETMALL_WECHAT_PAY_APP_ID=
PETMALL_WECHAT_PAY_MCH_ID=
PETMALL_WECHAT_PAY_PRIVATE_KEY=
PETMALL_ALIPAY_APP_ID=
PETMALL_ALIPAY_PRIVATE_KEY=
PETMALL_ALIPAY_PUBLIC_KEY=

# App update
PETMALL_APP_UPDATE_ENABLED=false
PETMALL_APP_LATEST_VERSION_NAME=1.0.0
PETMALL_APP_LATEST_VERSION_CODE=100
PETMALL_APP_UPDATE_URL=
PETMALL_APP_RELEASE_NOTES=
