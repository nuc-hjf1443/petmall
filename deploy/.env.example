# Copy this file to deploy/.env when you need to override compose defaults.
# Do not put real production secrets in version control.

PETMALL_IMAGE_TAG=local
PETMALL_DOCKER_NETWORK=petmall_network
PETMALL_API_BIND_HOST=0.0.0.0
PETMALL_API_PUBLISHED_PORT=8000
PETMALL_FRONTEND_BIND_HOST=0.0.0.0
PETMALL_FRONTEND_PUBLISHED_PORT=8080
PETMALL_MYSQL_BIND_HOST=127.0.0.1
PETMALL_MYSQL_PUBLISHED_PORT=3306
PETMALL_REDIS_BIND_HOST=127.0.0.1
PETMALL_REDIS_PUBLISHED_PORT=6379
PETMALL_RABBITMQ_BIND_HOST=127.0.0.1
PETMALL_RABBITMQ_PUBLISHED_PORT=5672
PETMALL_RABBITMQ_MANAGEMENT_PUBLISHED_PORT=15672
PETMALL_OLLAMA_BIND_HOST=127.0.0.1
PETMALL_OLLAMA_PUBLISHED_PORT=11434
PETMALL_POSTGRES_BIND_HOST=127.0.0.1
PETMALL_POSTGRES_PUBLISHED_PORT=5432
VITE_API_BASE_URL=/api
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
NPM_REGISTRY=https://registry.npmmirror.com

PETMALL_APP_NAME=PetMall
PETMALL_ENV=development
PETMALL_DEBUG=false
PETMALL_API_HOST=0.0.0.0
PETMALL_API_PORT=8000
PETMALL_PUBLIC_H5_URL=http://127.0.0.1:8080
PETMALL_CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

PETMALL_MYSQL_DATABASE=petmall
PETMALL_MYSQL_ROOT_PASSWORD=change_me
# Leave empty to let docker-compose derive it from PETMALL_MYSQL_ROOT_PASSWORD and PETMALL_MYSQL_DATABASE.
PETMALL_MYSQL_DB_URI=
PETMALL_REDIS_URL=redis://redis:6379/0
PETMALL_RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

PETMALL_JWT_SECRET_KEY=change_me_in_deploy_env
PETMALL_JWT_ALGORITHM=HS256
PETMALL_ACCESS_TOKEN_EXPIRE_MINUTES=1440

PETMALL_GENERATED_ASSET_DIR=generated
PETMALL_VECTOR_STORE_DIR=generated/private/vector_store
PETMALL_MAX_UPLOAD_SIZE_MB=20

PETMALL_PAYMENT_MODE=mock
PETMALL_MOCK_PAYMENT_ENABLED=true
PETMALL_ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
PETMALL_ALIPAY_APP_ID=
PETMALL_ALIPAY_PRIVATE_KEY=
PETMALL_ALIPAY_PUBLIC_KEY=
PETMALL_ALIPAY_SELLER_ID=
PETMALL_ALIPAY_NOTIFY_URL=http://127.0.0.1:8000/payments/alipay/notify
PETMALL_ALIPAY_RETURN_URL=http://127.0.0.1:8080/#/pages/payment/result

PETMALL_LLM_PROVIDER=deepseek
PETMALL_LLM_MODEL=deepseek-chat
PETMALL_LLM_API_KEY=
PETMALL_LLM_TEMPERATURE=0.2
PETMALL_RAG_CHUNK_SIZE=800
PETMALL_RAG_CHUNK_OVERLAP=100
PETMALL_OLLAMA_BASE_URL=http://ollama:11434
PETMALL_OLLAMA_EMBED_MODEL=nomic-embed-text
PETMALL_CHROMA_COLLECTION=petmall_knowledge
PETMALL_KNOWLEDGE_TASK_LEASE_SECONDS=900

# SMS
# Required for real SMS sending. Get the template id from Spug Push, for example A27L-xxxx.
PETMALL_SPUG_SMS_BASE_URL=https://push.spug.cc
PETMALL_SPUG_SMS_TEMPLATE_ID=
PETMALL_SPUG_SMS_TEMPLATE_NAME=PetMall
PETMALL_SPUG_SMS_CODE_PARAM_NAME=code
PETMALL_SPUG_SMS_TIMEOUT_SECONDS=10
PETMALL_SMS_CODE_EXPIRE_SECONDS=300
PETMALL_SMS_SEND_COOLDOWN_SECONDS=60
# Development/demo only. When true, the backend returns debug_code instead of sending SMS.
PETMALL_SMS_DEBUG_CODE_ENABLED=false

PETMALL_POSTGRES_DATABASE=petmall_agent
PETMALL_POSTGRES_USER=petmall
PETMALL_POSTGRES_PASSWORD=change_me
PETMALL_AGENT_MEMORY_POSTGRES_DSN=
PETMALL_AGENT_MEMORY_SETUP_ON_START=false
