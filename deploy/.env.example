# Copy this file to deploy/.env when you need to override compose defaults.
# Do not put real production secrets in version control.

PETMALL_IMAGE_TAG=local
PETMALL_DOCKER_NETWORK=petmall_network
PETMALL_API_PUBLISHED_PORT=8000
PETMALL_FRONTEND_PUBLISHED_PORT=8080
PETMALL_MYSQL_PUBLISHED_PORT=3306
PETMALL_REDIS_PUBLISHED_PORT=6379
PETMALL_RABBITMQ_PUBLISHED_PORT=5672
PETMALL_RABBITMQ_MANAGEMENT_PUBLISHED_PORT=15672
VITE_API_BASE_URL=/api

PETMALL_APP_NAME=PetMall
PETMALL_ENV=development
PETMALL_DEBUG=false
PETMALL_PUBLIC_H5_URL=http://127.0.0.1:8080
PETMALL_CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

PETMALL_MYSQL_DATABASE=petmall
PETMALL_MYSQL_ROOT_PASSWORD=change_me
# Leave empty to let docker-compose derive it from PETMALL_MYSQL_ROOT_PASSWORD and PETMALL_MYSQL_DATABASE.
PETMALL_MYSQL_DB_URI=
PETMALL_REDIS_URL=redis://redis:6379/0
PETMALL_RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

PETMALL_JWT_SECRET_KEY=change_me_in_deploy_env
PETMALL_PAYMENT_MODE=mock
PETMALL_MOCK_PAYMENT_ENABLED=true

PETMALL_LLM_PROVIDER=deepseek
PETMALL_LLM_MODEL=deepseek-chat
PETMALL_LLM_API_KEY=
PETMALL_OLLAMA_BASE_URL=http://ollama:11434
PETMALL_OLLAMA_EMBED_MODEL=nomic-embed-text

PETMALL_POSTGRES_DATABASE=petmall_agent
PETMALL_POSTGRES_USER=petmall
PETMALL_POSTGRES_PASSWORD=change_me
PETMALL_AGENT_MEMORY_POSTGRES_DSN=
PETMALL_AGENT_MEMORY_SETUP_ON_START=false
